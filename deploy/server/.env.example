# Скопируйте в /opt/itmen-pipeline/.env и задайте значения
PB_HTTP=127.0.0.1:8095
PB_DATA_DIR=/opt/itmen-pipeline/pb_data
PB_MIGRATIONS_DIR=/opt/itmen-pipeline/pb_migrations

# PocketBase superuser (создаётся setup.sh)
PB_ADMIN_EMAIL=admin@itmen-pipeline.local
PB_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Express API (pipeline load/save)
API_PORT=3010
PB_URL=http://127.0.0.1:8095

STAGING_GAS_URL=https://script.google.com/macros/s/AKfycbznkPIdUDj0mG8XdZ5lprz13u6r5DqqlpFj4EwOlc2vcgidwyGh2clHQv_dC2ro8WJ42w/exec

# Публичный URL
PUBLIC_URL=https://itmen-pipeline.nwlvl.ru

# Почта (Selectel Email Service → smtp.mail.selcloud.ru:1127 TLS)
# Логин/пароль: панель Selectel → Почтовый сервис → ресурс → Информация
SMTP_HOST=smtp.mail.selcloud.ru
SMTP_PORT=1127
SMTP_SECURE=1
SMTP_USER=
SMTP_PASS=
MAIL_FROM=ITMen Pipeline <noreply@nwlvl.ru>
